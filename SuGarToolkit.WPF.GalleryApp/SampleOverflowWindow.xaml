<Window
    x:Class="SuGarToolkit.WPF.GalleryApp.SampleOverflowWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SuGarToolkit.WPF.GalleryApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:windows="clr-namespace:SuGarToolkit.WPF.Controls.Windows;assembly=SuGarToolkit.WPF.Controls.Windows"
    Title="SampleOverflowWindow"
    Width="480"
    Height="320"
    Background="Transparent"
    mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="-1" />
    </WindowChrome.WindowChrome>

    <StackPanel Margin="0,48,0,0" VerticalAlignment="Center">
        <TextBlock
            HorizontalAlignment="Center"
            FontSize="24"
            FontWeight="SemiBold"
            Text="您已经在使用 Microsoft Edge 进行浏览" />
        <Border Height="8" />
        <TextBlock
            HorizontalAlignment="Center"
            FontSize="18"
            Text="在此处查看最新功能" />
        <Border Height="8" />
        <Button HorizontalAlignment="Center" Content="查看新功能" />
        <Border Height="8" />
        <TextBlock HorizontalAlignment="Center" Text="继续下载 Edge" />
    </StackPanel>

    <windows:WindowOverflowOverlay.WindowOverflowOverlay>
        <windows:WindowOverflowOverlay Margin="0,-36,0,0">
            <Grid>
                <Image
                    Width="128"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    IsHitTestVisible="False"
                    Source="/Resources/Edge.png" />
                <Grid.Effect>
                    <DropShadowEffect
                        BlurRadius="16"
                        Direction="270"
                        Opacity="0.382" />
                </Grid.Effect>
            </Grid>
        </windows:WindowOverflowOverlay>
    </windows:WindowOverflowOverlay.WindowOverflowOverlay>

</Window>
