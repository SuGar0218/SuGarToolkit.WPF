<Window
    x:Class="SuGarToolkit.WPF.GalleryApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SuGarToolkit.WPF.GalleryApp.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:decorators="clr-namespace:SuGarToolkit.WPF.Controls.Decorators;assembly=SuGarToolkit.WPF.Controls.Decorators"
    xmlns:local="clr-namespace:SuGarToolkit.WPF.GalleryApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:textBoxHelpers="clr-namespace:SuGarToolkit.WPF.TextBoxHelpers;assembly=SuGarToolkit.WPF.TextBoxHelpers"
    Title="MainWindow"
    Width="800"
    Height="450"
    mc:Ignorable="d">

    <Window.Resources>
        <Style BasedOn="{StaticResource {x:Type TextBox}}" TargetType="TextBox">
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <StackPanel>
        <TextBox
            textBoxHelpers:TextBoxInputMonitor.InputMethodEditingComplete="TextBox_InputMethodEditingComplete"
            textBoxHelpers:TextBoxInputMonitor.InputMethodEditingStart="TextBox_InputMethodEditingStart"
            textBoxHelpers:TextBoxInputMonitor.IsEnabled="True"
            textBoxHelpers:TextBoxInputMonitor.TextReallyChanged="TextBox_TextReallyChanged" />
        <Border Height="8" />
        <decorators:LiquidGlassLikeInteractionDecorator HorizontalAlignment="Center">
            <Border
                Background="Transparent"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="15">
                <TextBox
                    Width="240"
                    Height="30"
                    Margin="8,0"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0" />
            </Border>
        </decorators:LiquidGlassLikeInteractionDecorator>
        <Border Height="8" />
        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
            <Border Width="8" />
            <decorators:LiquidGlassLikeInteractionDecorator>
                <controls:CapsuleButton
                    Height="30"
                    Padding="8,0"
                    Click="OnCapsuleButtonClick"
                    Content="LiquidGlass like button" />
            </decorators:LiquidGlassLikeInteractionDecorator>
            <Border Width="8" />
            <decorators:LiquidGlassLikeInteractionDecorator>
                <controls:CapsuleButton
                    Width="30"
                    Height="30"
                    Content="+"
                    FontFamily="Microsoft Sans Serif"
                    FontSize="24" />
            </decorators:LiquidGlassLikeInteractionDecorator>
        </StackPanel>
    </StackPanel>
</Window>
